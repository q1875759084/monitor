{
  "name": "@q1875759084/monitor",
  "version": "0.1.0",
  "description": "A lightweight frontend monitoring SDK for performance, error tracking, and user behavior",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/q1875759084/monitor.git"
  },
  "keywords": [
    "monitor",
    "performance",
    "error-tracking",
    "frontend"
  ],
  "author": "q1875759084",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "web-vitals": "4.2.4"
  }
}
